{
  "database": {
    "rules": "backend/database.rules.json"
  },
  "storage": {
    "rules": "backend/storage.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
